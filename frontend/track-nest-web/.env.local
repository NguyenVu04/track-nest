NEXT_PUBLIC_USER_TRACKING_API_URL=https://api.tracknestapp.org
NEXT_PUBLIC_EMERGENCY_OPS_API_URL=https://api.tracknest.org/emergency-ops
NEXT_PUBLIC_CRIMINAL_REPORTS_API_URL=http://api.tracknestapp.org/criminal-reports

# Dev Keycloak proxy — browser calls localhost, proxy forwards server-to-server (no CORS)
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:3001/api/keycloak
# Server-side only: the real Keycloak upstream (not sent to browser)
KEYCLOAK_UPSTREAM_URL=https://tracknestapp.org/auth