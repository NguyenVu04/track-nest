{
  "name": "tracknest-k6",
  "version": "1.0.0",
  "description": "k6 performance tests for TrackNest user-tracking gRPC service",
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "tracking:smoke":  "k6 run scripts/user-tracking/smoke.js",
    "tracking:load":   "k6 run scripts/user-tracking/load.js",
    "tracking:stress": "k6 run scripts/user-tracking/stress.js",
    "tracking:spike":  "k6 run scripts/user-tracking/spike.js",

    "tracking:smoke:out":  "k6 run --out json=results/user-tracking-smoke-raw.json  scripts/user-tracking/smoke.js",
    "tracking:load:out":   "k6 run --out json=results/user-tracking-load-raw.json   scripts/user-tracking/load.js",
    "tracking:stress:out": "k6 run --out json=results/user-tracking-stress-raw.json scripts/user-tracking/stress.js",
    "tracking:spike:out":  "k6 run --out json=results/user-tracking-spike-raw.json  scripts/user-tracking/spike.js",

    "emergency:smoke":  "k6 run scripts/emergency-ops/smoke.js",
    "emergency:load":   "k6 run scripts/emergency-ops/load.js",
    "emergency:stress": "k6 run scripts/emergency-ops/stress.js",
    "emergency:spike":  "k6 run scripts/emergency-ops/spike.js",

    "emergency:smoke:out":  "k6 run --out json=results/emergency-ops-smoke-raw.json  scripts/emergency-ops/smoke.js",
    "emergency:load:out":   "k6 run --out json=results/emergency-ops-load-raw.json   scripts/emergency-ops/load.js",
    "emergency:stress:out": "k6 run --out json=results/emergency-ops-stress-raw.json scripts/emergency-ops/stress.js",
    "emergency:spike:out":  "k6 run --out json=results/emergency-ops-spike-raw.json  scripts/emergency-ops/spike.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/k6": "^1.7.0"
  }
}
